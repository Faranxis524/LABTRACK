rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write inventory
    match /inventory/{docId} {
      allow read, write: if request.auth != null;
      // Validate fields on create/update
      allow create: if request.resource.data.keys().hasAll(['name', 'stock', 'reorder', 'critical', 'unit'])
                     && request.resource.data.name is string
                     && request.resource.data.stock is number
                     && request.resource.data.reorder is number
                     && request.resource.data.critical is number
                     && request.resource.data.unit is string;
    }

    // Issuances
    match /issuances/{docId} {
      allow read, write: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['itemId', 'qty', 'departmentId', 'requester', 'issuedBy'])
                     && request.resource.data.qty is number
                     && request.resource.data.qty > 0;
    }

    // Departments
    match /departments/{docId} {
      allow read, write: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name'])
                     && request.resource.data.name is string
                     && request.resource.data.name.size() >= 2;
    }

    // Categories
    match /categories/{docId} {
      allow read, write: if request.auth != null;
      allow create: if request.resource.data.keys().hasAll(['name'])
                     && request.resource.data.name is string
                     && request.resource.data.name.size() >= 2;
    }
  }
}
